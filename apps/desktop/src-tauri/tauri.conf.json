{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeysArk",
  "version": "0.0.0",
  "identifier": "com.keysark.desktop",
  "build": {
    "devUrl": "http://localhost:6134",
    "frontendDist": "../dist-placeholder"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["sidecar/**/*"]
  }
}
